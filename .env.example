# ── Flask ─────────────────────────────────────────────────────
FLASK_ENV=development
FLASK_DEBUG=0
SECRET_KEY=change-this-to-a-strong-random-secret-key-min-32-chars

# ── Supabase ──────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SECRET_KEY=your-supabase-secret-key-here
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_STORAGE_BUCKET=mercx-assets

# ── Email (SMTP) ──────────────────────────────────────────────
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=your@email.com
MAIL_PASSWORD=your-app-password
MAIL_DEFAULT_SENDER=MercX Digital <noreply@mercxdigital.com>

# ── Payment Gateways ──────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

FLUTTERWAVE_SECRET_KEY=FLWSECK_TEST-...
FLUTTERWAVE_PUBLIC_KEY=FLWPUBK_TEST-...
FLUTTERWAVE_WEBHOOK_SECRET=your-flw-webhook-secret

PAYSTACK_SECRET_KEY=sk_test_...
PAYSTACK_PUBLIC_KEY=pk_test_...

# ── Redis (for rate limiting & caching) ───────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Security ──────────────────────────────────────────────────
WTF_CSRF_SECRET_KEY=another-strong-random-key-here
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_HTTPONLY=true
SESSION_COOKIE_SAMESITE=Lax
PERMANENT_SESSION_LIFETIME=1440

# ── App Config ────────────────────────────────────────────────
SITE_URL=http://localhost:5000
MAX_CONTENT_LENGTH=52428800
COMMISSION_RATE=10
